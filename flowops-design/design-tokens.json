      "lineHeight": 1.35
    },
    "body": {
      "fontSize": 15,
      "fontWeight": 500,
      "lineHeight": 1.5
    },
    "caption": {
      "fontSize": 13,
      "fontWeight": 500,
      "lineHeight": 1.45
