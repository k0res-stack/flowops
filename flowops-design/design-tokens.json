{
  "project": {
    "name": "FlowOps",
    "concept": "Quiet Command Center",
    "canvas": {
      "width": 1440,
      "height": 1024
    }
  },
  "colors": {
    "ink900": "#132033",
    "ink700": "#304156",
    "ink500": "#5E6B7B",
    "canvas": "#F5F3EE",
    "surface": "#FFFCF7",
    "line": "#DDD7CC",
    "primary": "#0EA5A4",
    "primaryDark": "#0B6E6D",
    "accentLime": "#C7F36B",
    "warning": "#F4A261",
    "warningDark": "#A35A00",
    "danger": "#E76F51",
    "success": "#2A9D8F",
    "successDark": "#1F7A5C",
